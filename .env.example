# =============================================================
# ASD Management Backend — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================

# --- Django core ---
SECRET_KEY=change-me-with-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Database (production only — dev uses SQLite) ---
POSTGRES_DATABASE=asd_management
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- HTTPS / SSL (production only) ---
# Set to true only after confirming a trusted reverse proxy (nginx/caddy) is the
# sole entry point and strips/sets X-Forwarded-Proto correctly.
# When true, also enables SECURE_SSL_REDIRECT automatically (can be overridden below).
TRUST_PROXY_SSL_HEADER=false

# Override SSL redirect independently if needed (defaults to same value as TRUST_PROXY_SSL_HEADER)
# SECURE_SSL_REDIRECT=true

# --- HSTS (production only — enable gradually) ---
# HSTS tells browsers to always use HTTPS for this domain.
# Enable in steps to avoid locking yourself out if HTTPS is misconfigured.
#
# Step 1 — first deploy: start with 5 minutes to test safely
SECURE_HSTS_SECONDS=300
# Step 2 — once HTTPS is confirmed working: raise to 1 year
# SECURE_HSTS_SECONDS=31536000
#
# Step 3 — only after confirming ALL subdomains are HTTPS-ready
SECURE_HSTS_INCLUDE_SUBDOMAINS=false
#
# Step 4 — submits domain to browser preload lists (very hard to reverse, enable last)
SECURE_HSTS_PRELOAD=false

# --- Monitoring (production only) ---
# SENTRY_DSN=https://your-sentry-dsn
