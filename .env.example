# =============================================================================
# ASD Management Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your local environment.
# Never commit .env to version control.
# In production, set these variables directly in the platform dashboard.
# =============================================================================

# --- Django core -------------------------------------------------------------
# Generate with command:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=
DJANGO_SETTINGS_MODULE=config.settings.development

# --- Allowed Hosts & CORS ----------------------------------------------------
# Comma-separated lists.
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Database (production only — dev uses SQLite) ----------------------------
POSTGRES_DATABASE=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=5432

# --- HTTPS / SSL (production only) -------------------------------------------
# Set TRUST_PROXY_SSL_HEADER=true only when nginx/caddy is the sole entry point.
# When true, SECURE_SSL_REDIRECT defaults to true automatically.
TRUST_PROXY_SSL_HEADER=false
# SECURE_SSL_REDIRECT=true

# --- HSTS (production only — enable gradually) --------------------------------
# Step 1 — test with 5 minutes
SECURE_HSTS_SECONDS=300
# Step 2 — raise to 1 year once HTTPS is confirmed: SECURE_HSTS_SECONDS=31536000
# Step 3 — only if ALL subdomains are HTTPS-ready
SECURE_HSTS_INCLUDE_SUBDOMAINS=false
# Step 4 — very hard to reverse, enable last
SECURE_HSTS_PRELOAD=false

# --- Seed DB (development only) ----------------------------------------------
# Required only when running: python manage.py seed_db
SEED_SUPERADMIN_USERNAME=
SEED_SUPERADMIN_EMAIL=
SEED_SUPERADMIN_PASSWORD=
SEED_ADMIN_USERNAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
